    {
      "id": "fixture-popup-target-routing",
      "name": "Focus and operate a newly opened popup target",
      "tags": [
        "local",
        "popup",
        "targets",
        "tab-scope"
      ],
      "actions": [
        {
          "open": {
            "url": "${FIXTURES}/popup-opener.html",
            "save_as": "popup_opener"
          }
        },
        {
          "wait_for": {
            "condition": "title:Popup Opener Fixture",
            "timeout_ms": 5000
          }
        },
        {
          "snapshot": {
            "min_elements": 1,
            "require": [
              {
                "role": "button",
                "name_contains": "Open synthetic popup",
                "save_as": "open_popup"
              }
            ]
          }
        },
        {
          "click": {
            "target": "open_popup"
          }
        },
        {
          "wait_for_tab": {
            "url_contains": "popup-child.html",
            "new_only": true,
            "save_as": "popup_child",
            "focus": true,
            "timeout_ms": 5000
          }
        },
        {
          "wait_for": {
            "condition": "title:Popup Child Fixture",
            "timeout_ms": 5000
          }
        },
        {
          "read": {
            "title_contains": "Popup Child Fixture",
            "main_contains": [
              "popup target content"
            ]
          }
        },
        {
          "snapshot": {
            "min_elements": 2,
            "require": [
              {
                "role": "textbox",
                "name_contains": "Popup note",
                "save_as": "popup_note"
              },
              {
                "role": "button",
                "name_contains": "Save popup note",
                "save_as": "save_popup"
              }
            ]
          }
        },
        {
          "fill": {
            "target": "popup_note",
            "text": "target scoped popup",
            "replace": true
          }
        },
        {
          "click": {
            "target": "save_popup"
          }
        },
        {
          "wait_for": {
            "condition": "text:Popup saved: target scoped popup",
            "timeout_ms": 5000
          }
        },
        {
          "read": {
            "title_contains": "Popup Child Fixture",
            "main_contains": [
              "Popup saved: target scoped popup"
            ]
          }
        },
        {
          "focus_tab": {
            "target": "popup_opener"
          }
        },
        {
          "wait_for": {
            "condition": "title:Popup Opener Fixture",
            "timeout_ms": 5000
          }
        },
        {
          "read": {
            "title_contains": "Popup Opener Fixture",
            "main_contains": [
              "synthetic popup target"
            ]
          }
        },
        {
          "focus_tab": {
            "target": "popup_child"
          }
        },
        {
          "read": {
            "title_contains": "Popup Child Fixture",
            "main_contains": [
              "Popup saved: target scoped popup"
            ]
          }
        }
      ]
    },
