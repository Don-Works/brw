{
  "version": 1,
  "scenarios": [
    {
      "id": "fixture-content-read",
      "name": "Read structured article content",
      "tags": [
        "local",
        "readability",
        "tables",
        "metadata"
      ],
      "actions": [
        {
          "open": {
            "url": "${FIXTURES}/content.html"
          }
        },
        {
          "wait_for": {
            "condition": "title:Readable Content Fixture",
            "timeout_ms": 5000
          }
        },
        {
          "snapshot": {
            "min_elements": 4,
            "require": [
              {
                "role": "link",
                "name_contains": "Skip to main",
                "save_as": "skip"
              },
              {
                "role": "link",
                "name_contains": "CDP architecture",
                "save_as": "cdp_link"
              }
            ]
          }
        },
        {
          "read": {
            "title_contains": "Readable Content Fixture",
            "main_contains": [
              "semantic browser coverage",
              "Screenshots are useful only for visual fallback"
            ],
            "min_headings": 2,
            "min_links": 4,
            "min_tables": 1,
            "metadata": {
              "description_contains": "Deterministic content fixture",
              "canonical_contains": "example.test/brw/content",
              "lang": "en"
            }
          }
        }
      ]
    },
    {
      "id": "fixture-form-actions",
      "name": "Type, select, click, and submit accessible form controls",
      "tags": [
        "local",
        "forms",
        "actions",
        "refs"
      ],
      "actions": [
        {
          "open": {
            "url": "${FIXTURES}/forms.html"
          }
        },
        {
          "wait_for": {
            "condition": "title:Form Interaction Fixture",
            "timeout_ms": 5000
          }
        },
        {
          "snapshot": {
            "min_elements": 8,
            "require": [
              {
                "role": "textbox",
                "name_contains": "Email",
                "save_as": "email"
              },
              {
                "role": "textbox",
                "name_contains": "Full name",
                "save_as": "full_name"
              },
              {
                "role": "combobox",
                "name_contains": "Plan",
                "save_as": "plan"
              },
              {
                "role": "checkbox",
                "name_contains": "Accept terms",
                "save_as": "terms"
              },
              {
                "role": "textbox",
                "name_contains": "Project notes",
                "save_as": "notes"
              },
              {
                "role": "textbox",
                "name_contains": "Attachment",
                "type": "file",
                "save_as": "attachment"
              },
              {
                "role": "button",
                "name_contains": "Submit request",
                "save_as": "submit"
              }
            ]
          }
        },
        {
          "type": {
            "target": "email",
            "text": "form@example.invalid"
          }
        },
        {
          "type": {
            "target": "full_name",
            "text": "Ada Lovelace"
          }
        },
        {
          "select": {
            "target": "plan",
            "value": "pro"
          }
        },
        {
          "click": {
            "target": "terms"
          }
        },
        {
          "type": {
            "target": "notes",
            "text": "Testing semantic refs"
          }
        },
        {
          "upload_file": {
            "target": "attachment",
            "path": "${FIXTURES}/upload.txt"
          }
        },
        {
          "click": {
            "target": "submit"
          }
        },
        {
          "wait_for": {
            "condition": "text:Submitted form@example.invalid Ada Lovelace pro accepted Testing semantic refs upload.txt",
            "timeout_ms": 5000
          }
        }
      ]
    },
    {
      "id": "fixture-custom-aria-combobox-commit",
      "name": "Commit a custom ARIA combobox option before continuing",
      "tags": [
        "local",
        "forms",
        "combobox",
        "listbox",
        "actions"
      ],
      "actions": [
        {
          "open": {
            "url": "${FIXTURES}/custom-combobox.html"
          }
        },
        {
          "wait_for": {
            "condition": "title:Custom ARIA Combobox Fixture",
            "timeout_ms": 5000
          }
        },
        {
          "snapshot": {
            "min_elements": 2,
            "require": [
              {
                "role": "combobox",
                "name_contains": "Release channel",
                "save_as": "channel"
              },
              {
                "role": "button",
                "name_contains": "Continue with channel",
                "save_as": "continue"
              }
            ]
          }
        },
        {
          "click": {
            "target": "continue"
          }
        },
        {
          "wait_for": {
            "condition": "text:Blocked: no committed channel",
            "timeout_ms": 5000
          }
        },
        {
          "click": {
            "target": "channel"
          }
        },
        {
          "snapshot": {
            "min_elements": 5,
            "require": [
              {
                "role": "listbox",
                "name_contains": "Draft channel",
                "save_as": "channel_list"
              },
              {
                "role": "option",
                "name_contains": "Stable channel",
                "save_as": "stable_channel"
              }
            ]
          }
        },
        {
          "click": {
            "target": "channel"
          }
        },
        {
          "select": {
            "target": "channel",
            "value": "Stable channel"
          }
        },
        {
          "click": {
            "target": "continue"
          }
        },
        {
          "wait_for": {
            "condition": "text:Result: committed channel stable",
            "timeout_ms": 5000
          }
        },
        {
          "read": {
            "title_contains": "Custom ARIA Combobox Fixture",
            "main_contains": [
              "Result: committed channel stable"
            ]
          }
        }
      ]
    },
    {
      "id": "fixture-dynamic-keyboard",
      "name": "Keyboard events and delayed dynamic controls",
      "tags": [
        "local",
        "dynamic",
        "keyboard",
        "wait"
      ],
      "actions": [
        {
          "open": {
            "url": "${FIXTURES}/dynamic.html"
          }
        },
        {
          "wait_for": {
            "condition": "title:Dynamic Interaction Fixture",
            "timeout_ms": 5000
          }
        },
        {
          "snapshot": {
            "min_elements": 3,
            "require": [
              {
                "role": "searchbox",
                "name_contains": "Knowledge search",
                "save_as": "search"
              },
              {
                "role": "button",
                "name_contains": "Search now",
                "save_as": "search_button"
              },
              {
                "role": "button",
                "name_contains": "Load delayed controls",
                "save_as": "load"
              }
            ]
          }
        },
        {
          "type": {
            "target": "search",
            "text": "semantic search"
          }
        },
        {
          "press": {
            "key": "Enter"
          }
        },
        {
          "wait_for": {
            "condition": "text:Search submitted: semantic search",
            "timeout_ms": 5000
          }
        },
        {
          "click": {
            "target": "load"
          }
        },
        {
          "wait_for": {
            "condition": "text:Delayed Notes",
            "timeout_ms": 5000
          }
        },
        {
          "snapshot": {
            "min_elements": 5,
            "require": [
              {
                "role": "textbox",
                "name_contains": "Delayed Notes",
                "save_as": "delayed_notes"
              },
              {
                "role": "button",
                "name_contains": "Save delayed notes",
                "save_as": "save_delayed"
              }
            ]
          }
        },
        {
          "type": {
            "target": "delayed_notes",
            "text": "async control works"
          }
        },
        {
          "click": {
            "target": "save_delayed"
          }
        },
        {
          "wait_for": {
            "condition": "text:Saved delayed note: async control works",
            "timeout_ms": 5000
          }
        }
      ]
    },
