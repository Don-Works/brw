    {
      "id": "fixture-assert-tools",
      "name": "Web-first assertions pass on visible elements",
      "tags": [
        "local",
        "assertions",
        "actions"
      ],
      "actions": [
        {
          "open": {
            "url": "${FIXTURES}/forms.html"
          }
        },
        {
          "wait_for": {
            "condition": "title:Form Interaction Fixture",
            "timeout_ms": 5000
          }
        },
        {
          "snapshot": {
            "require": [
              {
                "role": "textbox",
                "name_contains": "Email",
                "save_as": "email"
              },
              {
                "role": "button",
                "name_contains": "Submit request",
                "save_as": "submit"
              }
            ]
          }
        },
        {
          "assert_visible": {
            "target": "submit",
            "timeout_ms": 3000
          }
        },
        {
          "type": {
            "target": "email",
            "text": "assert@example.invalid"
          }
        },
        {
          "assert_value": {
            "target": "email",
            "value": "assert@example.invalid",
            "timeout_ms": 3000
          }
        }
      ]
    }
  ]
}
